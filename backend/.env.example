# Core application metadata.
APP_NAME=Cognitive Twin
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
# Optional: comma-separated list of additional allowed frontend origins.
# Example: FRONTEND_ORIGINS=http://127.0.0.1:5173,https://app.example.com
FRONTEND_ORIGINS=
# Emergency production interoperability toggle for cross-origin browser traffic.
# Set to false and configure FRONTEND_ORIGIN/FRONTEND_ORIGINS for strict CORS.
CORS_ALLOW_ALL=true

# Required: API key used for all OpenRouter requests.
OPENROUTER_API_KEY=your_api_key_here

# Optional: base URL for the OpenRouter API.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Required: default model used for simulation and general chat tasks.
DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct

# Local storage paths for persisted memory data.
MEMORY_JSON_PATH=../data/json
MEMORY_FAISS_PATH=../data/faiss
